---
import AdminLayout from '../../../layouts/AdminLayout.astro';import{createCmsClient}from'../../../lib/cms/supabase';const{data}=await createCmsClient(Astro.request,Astro.cookies)!.from('projects').select('*').order('sort_order');const projects=data??[];
---
<AdminLayout title="Projects" description="Manage project content without changing its public card design."><div class="admin-content"><div class="admin-actions"><a class="admin-button primary" href="/admin/projects/new">New project</a><a class="admin-button" href="/projects" target="_blank">View projects ↗</a></div><div class="panel"><table class="table"><thead><tr><th>ORDER</th><th>PROJECT</th><th>STATUS</th><th>VISIBLE</th><th>ACTIONS</th></tr></thead><tbody>{projects.map(p=><tr><td>{p.sort_order}</td><td><strong>{p.title}</strong><br/><small>{p.category}</small></td><td><span class="status">{p.status}</span></td><td>{p.visible?'Yes':'No'}</td><td><div class="actions"><a href={`/admin/projects/${p.id}`}>Edit</a><form method="post" action={`/api/admin/projects/${p.id}/delete`} onsubmit="return confirm('Delete this project?')"><button>Delete</button></form></div></td></tr>)}</tbody></table></div></div></AdminLayout><style>.actions{display:flex;gap:12px}.actions a,.actions button{border:0;background:none;color:var(--muted);padding:0;cursor:pointer}.actions a:hover,.actions button:hover{color:var(--accent)}</style>

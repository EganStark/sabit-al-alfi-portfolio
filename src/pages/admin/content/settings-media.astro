---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { createCmsClient } from '../../../lib/cms/supabase';
const cms=createCmsClient(Astro.request,Astro.cookies)!;
const [{data:settings},{data:objects,error:mediaError}]=await Promise.all([cms.from('site_settings').select('*').eq('id','primary').maybeSingle(),cms.storage.from('cms-media').list('library',{limit:100,sortBy:{column:'created_at',order:'desc'}})]);
const media=(objects??[]).filter(object=>object.name!=='.emptyFolderPlaceholder').map(object=>{const path=`library/${object.name}`;return{...object,path,url:cms.storage.from('cms-media').getPublicUrl(path).data.publicUrl,isImage:/\.(jpe?g|png|webp|avif)$/i.test(object.name)}});
---
<AdminLayout title="Settings & media" description="Control site metadata and reusable uploads without exposing design or code settings."><div class="admin-content content-stack">
  <section><div class="section-title"><div><span class="meta-label">SEO / GENERAL</span><h2>Site settings</h2></div><p>Page-specific titles still take priority; these values provide the site-wide defaults.</p></div><form class="panel form-grid" method="post" action="/api/admin/content/settings" enctype="multipart/form-data">
    <div class="field full"><label>DEFAULT SITE TITLE</label><input name="site_title" value={settings?.site_title??''} required/></div><div class="field full"><label>DEFAULT META DESCRIPTION</label><textarea name="default_description" maxlength="320" required>{settings?.default_description??''}</textarea></div>
    <div class="field"><label>AUTHOR / COPYRIGHT NAME</label><input name="author_name" value={settings?.author_name??''} required/></div><div class="field"><label>FOOTER TAGLINE</label><input name="footer_tagline" value={settings?.footer_tagline??''} required/></div>
    <div class="field"><label>CANONICAL SITE URL (OPTIONAL)</label><input name="site_url" type="url" value={settings?.site_url??''} placeholder="https://your-domain.com"/></div><div class="field"><label>NEW SOCIAL PREVIEW IMAGE</label><input name="og_image_file" type="file" accept="image/jpeg,image/png,image/webp,image/avif"/></div>
    <div class="field full"><label>CURRENT SOCIAL PREVIEW URL</label><input value={settings?.og_image_url??'/og-image.svg'} readonly/></div><div class="field full"><button class="admin-button primary">Save site settings</button></div>
  </form></section>
  <section><div class="section-title"><div><span class="meta-label">CMS MEDIA</span><h2>Media library</h2></div><p>Upload images and PDFs for reuse. Existing portfolio assets remain untouched.</p></div>
    <form class="panel upload-form" method="post" action="/api/admin/media" enctype="multipart/form-data"><div class="field"><label>FILE (IMAGE OR PDF, MAX 10 MB)</label><input name="media_file" type="file" accept="image/jpeg,image/png,image/webp,image/avif,application/pdf" required/></div><div class="field"><label>DESCRIPTIVE FILE NAME</label><input name="file_name" placeholder="research-presentation"/></div><button class="admin-button primary">Upload file</button></form>
    {mediaError&&<p class="notice">Media will appear after final permissions are applied.</p>}
    <div class="media-grid">{media.map(item=><article class="panel media-card">{item.isImage?<img src={item.url} alt="" loading="lazy"/>:<div class="file-mark">PDF</div>}<div><strong>{item.name}</strong><a href={item.url} target="_blank" rel="noreferrer">Open file ↗</a><button class="copy-link" type="button" data-url={item.url}>Copy URL</button><form method="post" action="/api/admin/media/delete"><input type="hidden" name="path" value={item.path}/><button class="danger confirm-delete" data-confirm="Delete this media file?">Delete</button></form></div></article>)}</div>
  </section>
</div></AdminLayout>
<script>document.querySelectorAll<HTMLButtonElement>('.copy-link').forEach(button=>button.addEventListener('click',async()=>{await navigator.clipboard.writeText(button.dataset.url??'');button.textContent='Copied'}));document.querySelectorAll<HTMLButtonElement>('.confirm-delete').forEach(button=>button.addEventListener('click',event=>{if(!window.confirm(button.dataset.confirm??'Delete this file?'))event.preventDefault()}));</script>
<style>.content-stack{display:grid;gap:56px}.section-title{display:flex;justify-content:space-between;gap:24px;align-items:end;margin-bottom:16px}.section-title h2{font:500 30px Space Grotesk;margin:.35rem 0 0}.section-title p{max-width:560px;color:var(--muted);margin:0}.upload-form{display:grid;grid-template-columns:1fr 1fr auto;gap:14px;align-items:end;margin-bottom:14px}.media-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px}.media-card{padding:0;overflow:hidden}.media-card img,.file-mark{width:100%;height:180px;object-fit:cover;background:#09090b}.file-mark{display:grid;place-items:center;font:500 28px JetBrains Mono;color:var(--accent)}.media-card>div{display:grid;gap:7px;padding:14px;overflow:hidden}.media-card strong{overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.media-card a,.media-card button{width:max-content;border:0;padding:0;background:none;color:var(--muted);cursor:pointer}.media-card a:hover,.media-card button:hover{color:var(--accent)}.media-card .danger:hover{color:#ff9b9b}@media(max-width:900px){.media-grid{grid-template-columns:repeat(2,1fr)}}@media(max-width:650px){.section-title{display:block}.section-title p{margin-top:.6rem}.upload-form,.media-grid{grid-template-columns:1fr}}</style>

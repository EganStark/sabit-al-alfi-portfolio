---
import AdminLayout from '../../../layouts/AdminLayout.astro';import{createCmsClient}from'../../../lib/cms/supabase';const{data}=await createCmsClient(Astro.request,Astro.cookies)!.from('profile_content').select('*').eq('id','primary').maybeSingle();const p=data??{};
---
<AdminLayout title="Home & profile" description="Edit identity and profile content while preserving the public composition."><div class="admin-content"><form class="panel form-grid" method="post" action="/api/admin/profile" enctype="multipart/form-data"><div class="field"><label>DISPLAY NAME</label><input name="display_name" value={p.display_name??''} required/></div><div class="field"><label>ROLE LINE</label><input name="role_line" value={p.role_line??''} required/></div><div class="field full"><label>HERO HEADLINE</label><input name="hero_headline" value={p.hero_headline??''} required/></div><div class="field full"><label>HERO INTRODUCTION</label><textarea name="hero_intro" required>{p.hero_intro??''}</textarea></div><div class="field"><label>LOCATION</label><input name="location" value={p.location??''}/></div><div class="field"><label>FOCUS</label><input name="focus_label" value={p.focus_label??''}/></div><div class="field"><label>WORK MODE</label><input name="work_mode" value={p.work_mode??''}/></div><label class="check"><input type="checkbox" name="availability_enabled" value="true" checked={p.availability_enabled??true}/> Show availability</label><div class="field"><label>AVAILABILITY TITLE</label><input name="availability_title" value={p.availability_title??''}/></div><div class="field"><label>AVAILABILITY DETAIL</label><input name="availability_detail" value={p.availability_detail??''}/></div><div class="field full"><label>HOME ABOUT HEADLINE</label><input name="home_about_headline" value={p.home_about_headline??''}/></div><div class="field full"><label>HOME ABOUT DESCRIPTION</label><textarea name="home_about_description">{p.home_about_description??''}</textarea></div><div class="field"><label>ABOUT HEADLINE</label><input name="about_headline" value={p.about_headline??''}/></div><div class="field"><label>ABOUT INTRO</label><textarea name="about_intro">{p.about_intro??''}</textarea></div><div class="field full"><label>PRINCIPLES HEADLINE</label><input name="about_principles_headline" value={p.about_principles_headline??''}/></div><div class="field full"><label>ABOUT FOCUS</label><textarea name="about_focus">{p.about_focus??''}</textarea></div><div class="field full"><label>ABOUT DETAIL</label><textarea name="about_detail">{p.about_detail??''}</textarea></div><div class="field"><label>NEW PORTRAIT</label><input name="portrait_file" type="file" accept="image/jpeg,image/png,image/webp,image/avif"/></div><div class="field"><label>PORTRAIT ALT TEXT</label><input name="portrait_alt" value={p.portrait_alt??''}/></div><div class="field"><label>NEW CV</label><input name="cv_file" type="file" accept="application/pdf"/></div><div class="field full"><button class="admin-button primary">Save profile content</button></div></form></div></AdminLayout>

---
import AdminLayout from '../../../layouts/AdminLayout.astro';import{createCmsClient}from'../../../lib/cms/supabase';const cms=createCmsClient(Astro.request,Astro.cookies)!;const[e,a]=await Promise.all([cms.from('experience_entries').select('*').order('sort_order'),cms.from('achievements').select('*').order('sort_order')]);const experiences=e.data??[],achievements=a.data??[];
---
<AdminLayout title="Experience & achievements" description="Add future roles, awards, hackathons, competitions, and presentations."><div class="admin-content stack"><section><h2>Experience</h2>{[...experiences,{id:'new',title:'',organization:'',period:'',location:'',description:'',url:'',sort_order:experiences.length+1,visible:true}].map(x=><form class="panel form-grid compact" method="post" action={`/api/admin/content/experience/${x.id}`}><div class="field"><label>ROLE</label><input name="title" value={x.title} required/></div><div class="field"><label>ORGANIZATION</label><input name="organization" value={x.organization} required/></div><div class="field"><label>PERIOD</label><input name="period" value={x.period}/></div><div class="field"><label>LOCATION</label><input name="location" value={x.location}/></div><div class="field full"><label>DESCRIPTION</label><textarea name="description">{x.description}</textarea></div><div class="field"><label>URL</label><input name="url" value={x.url??''}/></div><div class="field"><label>ORDER</label><input type="number" name="sort_order" value={x.sort_order}/></div><label class="check"><input type="checkbox" name="visible" value="true" checked={x.visible}/> Public</label><div class="admin-actions"><button class="admin-button primary">{x.id==='new'?'Add':'Save'}</button>{x.id!=='new'&&<button class="admin-button danger" name="intent" value="delete" formnovalidate>Delete</button>}</div></form>)}</section><section><h2>Awards & activities</h2>{[...achievements,{id:'new',kind:'Award',title:'',organization:'',event_date:'',description:'',url:'',sort_order:achievements.length+1,visible:true}].map(x=><form class="panel form-grid compact" method="post" action={`/api/admin/content/achievement/${x.id}`}><div class="field"><label>TYPE</label><select name="kind">{['Award','Hackathon','Presentation','Competition'].map(k=><option value={k} selected={x.kind===k}>{k}</option>)}</select></div><div class="field"><label>TITLE</label><input name="title" value={x.title} required/></div><div class="field"><label>ORGANIZATION / EVENT</label><input name="organization" value={x.organization}/></div><div class="field"><label>DATE</label><input type="date" name="event_date" value={x.event_date??''}/></div><div class="field full"><label>DESCRIPTION</label><textarea name="description">{x.description}</textarea></div><div class="field"><label>URL</label><input name="url" value={x.url??''}/></div><div class="field"><label>ORDER</label><input type="number" name="sort_order" value={x.sort_order}/></div><label class="check"><input type="checkbox" name="visible" value="true" checked={x.visible}/> Public</label><div class="admin-actions"><button class="admin-button primary">{x.id==='new'?'Add':'Save'}</button>{x.id!=='new'&&<button class="admin-button danger" name="intent" value="delete" formnovalidate>Delete</button>}</div></form>)}</section></div></AdminLayout>
<style>.stack{display:grid;gap:56px}.stack h2{font:500 30px Space Grotesk}.compact{margin-bottom:12px}.compact textarea{min-height:90px}</style>

---
import AdminLayout from '../../../layouts/AdminLayout.astro';import{createCmsClient}from'../../../lib/cms/supabase';const{data}=await createCmsClient(Astro.request,Astro.cookies)!.from('page_sections').select('*').order('page').order('sort_order');const sections=data??[];
---
<AdminLayout title="Page sections" description="Reorder or hide approved Home and About sections; core navigation and layout remain protected."><div class="admin-content"><form class="panel" method="post" action="/api/admin/content/sections"><table class="table"><thead><tr><th>PAGE</th><th>SECTION</th><th>ORDER</th><th>VISIBLE</th></tr></thead><tbody>{sections.map(x=><tr><td>{x.page}</td><td>{x.label}<input type="hidden" name="section_key" value={x.section_key}/></td><td><input name={`order_${x.section_key}`} type="number" min="0" value={x.sort_order}/></td><td><input name={`visible_${x.section_key}`} type="checkbox" value="true" checked={x.visible}/></td></tr>)}</tbody></table><button class="admin-button primary">Save section settings</button></form></div></AdminLayout>

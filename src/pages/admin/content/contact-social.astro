---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { createCmsClient } from '../../../lib/cms/supabase';
const cms=createCmsClient(Astro.request,Astro.cookies)!;
const [contentResult,linksResult]=await Promise.all([cms.from('contact_content').select('*').eq('id','primary').maybeSingle(),cms.from('social_links').select('*').order('sort_order')]);
const content=contentResult.data??{},links=linksResult.data??[];
---
<AdminLayout title="Contact & social" description="Manage contact copy and public profile links while retaining the portfolio layout."><div class="admin-content content-stack">
  <section><div class="section-title"><div><span class="meta-label">CONTACT COPY</span><h2>Contact experience</h2></div><p>The email address powers both the visible email row and the “Prepare email” form.</p></div><form class="panel form-grid" method="post" action="/api/admin/content/contact">
    <div class="field"><label>CONTACT EMAIL</label><input name="email" type="email" value={content.email??''} required /></div><div class="field"><label>FORM BUTTON LABEL</label><input name="form_button_label" value={content.form_button_label??''} required /></div>
    <div class="field full"><label>CONTACT PAGE HEADLINE</label><input name="page_headline" value={content.page_headline??''} required /></div><div class="field full"><label>CONTACT PAGE INTRO</label><textarea name="page_intro" required>{content.page_intro??''}</textarea></div>
    <div class="field"><label>ONLINE SECTION HEADLINE</label><input name="online_headline" value={content.online_headline??''} required /></div><div class="field"><label>ONLINE SECTION INTRO</label><textarea name="online_intro" required>{content.online_intro??''}</textarea></div>
    <div class="field full"><label>HOME CONTACT HEADLINE</label><input name="home_headline" value={content.home_headline??''} required /></div><div class="field full"><label>HOME CONTACT DESCRIPTION</label><textarea name="home_description" required>{content.home_description??''}</textarea></div>
    <div class="field full"><button class="admin-button primary">Save contact content</button></div>
  </form></section>
  <section><div class="section-title"><div><span class="meta-label">PUBLIC PROFILES</span><h2>Social links</h2></div><p>Use an official icon where available; “External” provides a neutral option for future profiles.</p></div><div class="record-stack">
    {[...links,{id:'new',label:'',display_value:'',url:'',icon:'external',sort_order:links.length+1,visible:true}].map(item=><form class="panel link-form" method="post" action={`/api/admin/content/social/${item.id}`}>
      <div class="field"><label>LABEL</label><input name="label" value={item.label} required /></div><div class="field"><label>DISPLAY VALUE</label><input name="display_value" value={item.display_value} required /></div><div class="field wide"><label>URL</label><input name="url" value={item.url} required /></div>
      <div class="field"><label>ICON</label><select name="icon">{['linkedin','github','gmail','document','external'].map(icon=><option value={icon} selected={item.icon===icon}>{icon}</option>)}</select></div><div class="field order"><label>ORDER</label><input name="sort_order" type="number" min="0" value={item.sort_order}/></div>
      <label class="check"><input name="visible" type="checkbox" value="true" checked={item.visible}/> Public</label><div class="record-actions"><button class="admin-button primary">{item.id==='new'?'Add link':'Save'}</button>{item.id!=='new'&&<button class="admin-button danger confirm-delete" name="intent" value="delete" formnovalidate data-confirm="Delete this social link?">Delete</button>}</div>
    </form>)}
  </div></section>
</div></AdminLayout>
<script>document.querySelectorAll<HTMLButtonElement>('.confirm-delete').forEach(button=>button.addEventListener('click',event=>{if(!window.confirm(button.dataset.confirm??'Delete this link?'))event.preventDefault()}));</script>
<style>.content-stack{display:grid;gap:56px}.section-title{display:flex;justify-content:space-between;gap:24px;align-items:end;margin-bottom:16px}.section-title h2{font:500 30px Space Grotesk;margin:.35rem 0 0}.section-title p{max-width:560px;color:var(--muted);margin:0}.record-stack{display:grid;gap:10px}.link-form{display:grid;grid-template-columns:.7fr .8fr 1.5fr .65fr 75px;gap:12px;align-items:end}.record-actions{display:flex;gap:8px}.wide{min-width:0}@media(max-width:1100px){.link-form{grid-template-columns:repeat(2,minmax(0,1fr))}}@media(max-width:650px){.section-title{display:block}.section-title p{margin-top:.6rem}.link-form{grid-template-columns:1fr}}</style>

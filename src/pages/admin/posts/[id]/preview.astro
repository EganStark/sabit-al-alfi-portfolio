---
import BaseLayout from '../../../../layouts/BaseLayout.astro';import SiteNav from '../../../../components/SiteNav.astro';import SiteFooter from '../../../../components/SiteFooter.astro';import{createCmsClient}from'../../../../lib/cms/supabase';const{data:post}=await createCmsClient(Astro.request,Astro.cookies)!.from('posts').select('*').eq('id',Astro.params.id).single();if(!post)return new Response('Post not found',{status:404});const paragraphs=post.body.split(/\n\s*\n/).map((x:string)=>x.trim()).filter(Boolean);
---
<BaseLayout title={`Preview: ${post.title}`} description={post.excerpt}><SiteNav/><main id="main-content"><div class="preview-bar">PRIVATE PREVIEW · {post.status}</div><article class="article container"><header><a href={`/admin/posts/${post.id}`}>← Return to editor</a><h1 class="display">{post.title}</h1><p class="dek">{post.excerpt}</p></header>{post.cover_url&&<figure><img src={post.cover_url} alt={post.cover_alt??''}/></figure>}<div class="body">{paragraphs.map((p:string)=><p>{p}</p>)}</div></article></main><SiteFooter/></BaseLayout>
<style>.preview-bar{padding:.7rem;text-align:center;background:var(--accent);color:#06110f;font:.65rem JetBrains Mono}.article{padding-block:5rem}.article h1{font-size:clamp(3rem,7vw,6rem);line-height:1;margin:2rem 0}.dek{color:var(--text-secondary);font-size:1.2rem}.article figure{margin:3rem 0}.article img{width:100%;max-height:650px;object-fit:cover}.body{max-width:760px;margin:auto;font-size:1.1rem;line-height:1.85}.body p{white-space:pre-wrap}</style>

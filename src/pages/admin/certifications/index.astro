---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { createCmsClient } from '../../../lib/cms/supabase';
let certifications: any[] = [];
const { data } = await createCmsClient(Astro.request, Astro.cookies)!.from('certifications').select('*').order('sort_order');
certifications = data ?? [];
---
<AdminLayout title="Certifications" description="Manage credentials while the portfolio controls their presentation.">
  <div class="admin-content"><div class="admin-actions"><a class="admin-button primary" href="/admin/certifications/new">New certification</a><a class="admin-button" href="/about" target="_blank">View About page ↗</a></div>
    <div class="panel">{certifications.length ? <table class="table"><thead><tr><th>ORDER</th><th>CERTIFICATION</th><th>STATUS</th><th>VISIBLE</th><th>ACTIONS</th></tr></thead><tbody>{certifications.map(item => <tr><td>{item.sort_order}</td><td><strong>{item.title}</strong><br /><small>{item.provider}</small></td><td><span class="status">{item.status === 'completed' ? 'Completed' : 'In progress'}</span></td><td>{item.visible ? 'Yes' : 'No'}</td><td><div class="row-actions"><a href={`/admin/certifications/${item.id}`}>Edit</a><form method="post" action={`/api/admin/certifications/${item.id}/delete`} onsubmit="return confirm('Delete this certification permanently?')"><button type="submit">Delete</button></form></div></td></tr>)}</tbody></table> : <p class="empty">Run the certifications migration, then refresh this page.</p>}</div>
  </div>
</AdminLayout>
<style>.row-actions{display:flex;gap:12px}.row-actions a,.row-actions button{border:0;background:none;padding:0;color:var(--muted);cursor:pointer}.row-actions a:hover,.row-actions button:hover{color:var(--accent)}.empty{color:var(--muted)}</style>


---
import AdminLayout from '../../../layouts/AdminLayout.astro';import{createCmsClient}from'../../../lib/cms/supabase';const{data}=await createCmsClient(Astro.request,Astro.cookies)!.from('research_papers').select('*').order('sort_order');const papers=data??[];
---
<AdminLayout title="Research" description="Manage publication records and authorship details."><div class="admin-content"><div class="admin-actions"><a class="admin-button primary" href="/admin/research/new">New paper</a><a class="admin-button" href="/research" target="_blank">View research ↗</a></div><div class="panel"><table class="table"><thead><tr><th>ORDER</th><th>PAPER</th><th>AUTHORSHIP</th><th>STATUS</th><th>ACTIONS</th></tr></thead><tbody>{papers.map(p=><tr><td>{p.sort_order}</td><td><strong>{p.title}</strong><br/><small>{p.publisher} · {p.publication_year}</small></td><td>{p.authorship_label}<br/><small>{p.author_position} of {p.author_count}</small></td><td><span class="status">{p.status}</span></td><td><div class="actions"><a href={`/admin/research/${p.id}`}>Edit</a><form method="post" action={`/api/admin/research/${p.id}/delete`} onsubmit="return confirm('Delete this paper?')"><button>Delete</button></form></div></td></tr>)}</tbody></table></div></div></AdminLayout><style>.actions{display:flex;gap:12px}.actions a,.actions button{border:0;background:none;color:var(--muted);padding:0;cursor:pointer}</style>

---
import BaseLayout from '../layouts/BaseLayout.astro'; import SiteNav from '../components/SiteNav.astro'; import SiteFooter from '../components/SiteFooter.astro'; import SignalLine from '../components/SignalLine.astro'; import BrandIcon from '../components/BrandIcon.astro'; import { createCmsClient } from '../lib/cms/supabase';
type IconName='gmail'|'linkedin'|'github'|'document'|'external';
let contact={email:'sabit.alfie@gmail.com',page_headline:'Let’s build something that matters.',page_intro:'Reach out about Data Science, ML and AI engineering roles, research, or thoughtful software collaborations.',online_headline:'Find me online.',online_intro:'For professional opportunities, research conversations, and collaborations.',form_button_label:'Prepare email'};
let links:{label:string;display_value:string;url:string;icon:IconName}[]=[{label:'LinkedIn',display_value:'/in/sabitalfi',url:'https://www.linkedin.com/in/sabitalfi/',icon:'linkedin'},{label:'GitHub',display_value:'@EganStark',url:'https://github.com/EganStark',icon:'github'}];
let cvUrl='/Sabit-Al-Alfi-CV.pdf';
if(Astro.locals.cmsConfigured){const cms=createCmsClient(Astro.request,Astro.cookies)!;const[contactResult,linksResult,profileResult]=await Promise.all([cms.from('contact_content').select('*').eq('id','primary').maybeSingle(),cms.from('social_links').select('label,display_value,url,icon,sort_order').eq('visible',true).order('sort_order'),cms.from('profile_content').select('cv_url').eq('id','primary').maybeSingle()]);if(contactResult.data)contact={...contact,...contactResult.data};if(linksResult.data?.length)links=linksResult.data as typeof links;if(profileResult.data?.cv_url)cvUrl=profileResult.data.cv_url}
---
<BaseLayout title="Contact — Sabit Al Alfi"><SiteNav /><main id="main-content"><header class="page-hero container"><p class="eyebrow">CONTACT / START A CONVERSATION</p><SignalLine /><h1 class="display">{contact.page_headline}</h1><p>{contact.page_intro}</p></header><section class="section"><div class="container contact-grid"><div><h2 class="display">{contact.online_headline}</h2><p class="muted">{contact.online_intro}</p><a class="contact-row" href={`mailto:${contact.email}`}><span class="contact-name"><BrandIcon name="gmail" />Email</span><span>{contact.email} ↗</span></a>{links.map(link=><a class="contact-row" href={link.url} target="_blank" rel="noreferrer"><span class="contact-name"><BrandIcon name={link.icon} />{link.label}</span><span>{link.display_value} ↗</span></a>)}<a class="contact-row" href={cvUrl} target="_blank"><span class="contact-name"><BrandIcon name="document" />Résumé</span><span>Short CV ↗</span></a></div><form class="card" data-contact-form novalidate><label>Name<input name="name" minlength="2" maxlength="100" required autocomplete="name" /></label><label>Email<input name="email" type="email" maxlength="254" required autocomplete="email" /></label><label class="honeypot" aria-hidden="true">Website<input name="website" tabindex="-1" autocomplete="off" /></label><label>Message<textarea name="message" rows="6" minlength="10" maxlength="5000" required></textarea></label><button class="button primary" type="submit">{contact.form_button_label} →</button><p class="form-status" aria-live="polite"></p></form></div></section></main><SiteFooter /><script>const form=document.querySelector<HTMLFormElement>('[data-contact-form]');form?.addEventListener('submit',async event=>{event.preventDefault();const status=form.querySelector<HTMLElement>('.form-status'),button=form.querySelector<HTMLButtonElement>('button[type=submit]');if(!form.checkValidity()){form.reportValidity();if(status)status.textContent='Please complete all fields correctly.';return}if(button)button.disabled=true;if(status)status.textContent='Sending…';try{const response=await fetch('/api/contact',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(Object.fromEntries(new FormData(form)))}),result=await response.json();if(!response.ok)throw new Error(result.error||'Delivery failed.');form.reset();if(status)status.textContent='Message sent successfully. Thank you.'}catch(error){if(status)status.textContent=error instanceof Error?error.message:'Delivery failed. Please use the email link.'}finally{if(button)button.disabled=false}});</script></BaseLayout>
<style>.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:clamp(2rem,7vw,7rem)}.contact-grid h2{font-size:clamp(2rem,4vw,3.5rem)}.contact-row{min-height:64px;display:flex;justify-content:space-between;gap:1rem;align-items:center;border-bottom:1px solid var(--border)}.contact-row:hover{color:var(--accent)}.contact-name{display:inline-flex;align-items:center;gap:.75rem;font-weight:500}.contact-name :global(.brand-icon){transition:transform .2s ease}.contact-row:hover .contact-name :global(.brand-icon){transform:translateY(-1px)}form{display:grid;gap:1.2rem}label{display:grid;gap:.45rem;font:500 .72rem "JetBrains Mono";text-transform:uppercase;color:var(--text-secondary)}input,textarea{width:100%;border:1px solid var(--border);border-radius:7px;padding:.8rem;background:var(--bg);color:var(--text-primary);text-transform:none}textarea{resize:vertical}.form-status{min-height:1.5rem;margin:0;color:var(--text-secondary);font-size:.8rem}@media(max-width:760px){.contact-grid{grid-template-columns:1fr}.contact-row{align-items:flex-start;flex-direction:column;justify-content:center;gap:.35rem}}</style>

---
import BaseLayout from '../layouts/BaseLayout.astro'; import SiteNav from '../components/SiteNav.astro'; import SiteFooter from '../components/SiteFooter.astro'; import SignalLine from '../components/SignalLine.astro'; import { getCollection } from 'astro:content'; import { createCmsClient } from '../lib/cms/supabase';
const fallback=(await getCollection('research')).sort((a,b)=>a.data.order-b.data.order).map(item=>item.data);let papers:any[]=fallback;if(Astro.locals.cmsConfigured){const{data}=await createCmsClient(Astro.request,Astro.cookies)!.from('research_papers').select('*').eq('visible',true).order('sort_order');if(data?.length)papers=data.map(p=>({title:p.title,status:p.status,abstract:p.abstract,link:p.publication_url,venue:p.venue,publisher:p.publisher,year:p.publication_year,doi:p.doi,authorshipLabel:p.authorship_label,authorPosition:p.author_position,authorCount:p.author_count,order:p.sort_order}))}
---
<BaseLayout title="Research — Sabit Al Alfi"><SiteNav /><main id="main-content"><header class="page-hero container"><p class="eyebrow">RESEARCH / PUBLICATION RECORD</p><SignalLine /><h1 class="display">Models should show their work.</h1><p>Four peer-reviewed conference publications across explainable AI, computer vision, agriculture, and environmental intelligence.</p></header><section class="section"><div class="container papers">{papers.map((paper,i)=><article><div class="number">0{i+1}</div><div class="paper-body"><div class="meta"><div class="badges"><span class="authorship">{paper.authorshipLabel}</span><span class="author-order">{paper.authorPosition} of {paper.authorCount} authors</span></div><span class="status">{paper.status}</span></div><h2 class="display">{paper.title}</h2><p class="muted">{paper.abstract}</p><dl><div><dt>Venue</dt><dd>{paper.venue}</dd></div><div><dt>Publisher / year</dt><dd>{paper.publisher} · {paper.year}</dd></div><div><dt>Authorship</dt><dd>Sabit Al Alfi · author {paper.authorPosition} of {paper.authorCount}</dd></div><div><dt>DOI</dt><dd>{paper.doi}</dd></div></dl>{paper.link&&<a class="button" href={paper.link} target="_blank" rel="noreferrer">View on {paper.publisher} ↗</a>}</div></article>)}</div></section></main><SiteFooter /></BaseLayout>
<style>.papers{border-top:1px solid var(--border)}.papers article{display:grid;grid-template-columns:70px 1fr;gap:1rem;padding:clamp(2.5rem,6vw,4.5rem) 0;border-bottom:1px solid var(--border)}.paper-body{min-width:0}.number{font:.75rem "JetBrains Mono";color:var(--accent)}.meta,.badges{display:flex;align-items:center;flex-wrap:wrap;gap:.55rem}.meta{justify-content:space-between}.authorship,.author-order,.status{padding:.32rem .55rem;border:1px solid var(--border);font:.62rem "JetBrains Mono";letter-spacing:.06em;text-transform:uppercase}.authorship{border-color:var(--accent);background:var(--accent-soft);color:var(--accent)}.author-order{color:var(--text-tertiary)}.status{color:var(--text-secondary)}.papers h2{max-width:940px;margin:1.3rem 0 .7rem;font-size:clamp(1.75rem,3.5vw,3rem);line-height:1.1}.papers>article:nth-child(n+3) h2{font-size:clamp(1.55rem,3vw,2.5rem)}.papers p{max-width:780px}dl{display:grid;grid-template-columns:1.35fr .65fr;margin:1.8rem 0 1.4rem;border-top:1px solid var(--border)}dl div{padding:.8rem 1rem .8rem 0;border-bottom:1px solid var(--border)}dt{font:.56rem "JetBrains Mono";letter-spacing:.08em;text-transform:uppercase;color:var(--text-tertiary)}dd{margin:.3rem 0 0;font-size:.82rem;overflow-wrap:anywhere}@media(max-width:600px){.papers article{grid-template-columns:1fr}.number{display:none}.meta{align-items:flex-start}.status{margin-left:0}dl{grid-template-columns:1fr}}</style>

---
import BaseLayout from '../layouts/BaseLayout.astro'; import SiteNav from '../components/SiteNav.astro'; import SiteFooter from '../components/SiteFooter.astro'; import SignalLine from '../components/SignalLine.astro'; import { getCollection } from 'astro:content'; import { createCmsClient } from '../lib/cms/supabase';
const fallback=(await getCollection('projects')).sort((a,b)=>a.data.order-b.data.order).map(item=>item.data);
let projects:any[]=fallback;
if(Astro.locals.cmsConfigured){const{data}=await createCmsClient(Astro.request,Astro.cookies)!.from('projects').select('*').eq('visible',true).order('sort_order');if(data?.length)projects=data.map(item=>({title:item.title,category:item.category,status:item.status,description:item.description,tags:item.tags,liveUrl:item.live_url,githubUrl:item.github_url,sourceVisibility:item.source_visibility,featured:item.featured,order:item.sort_order}))}
---
<BaseLayout title="Projects — Sabit Al Alfi"><SiteNav /><main id="main-content"><header class="page-hero container"><p class="eyebrow">PROJECTS / COMPLETE INDEX</p><SignalLine /><h1 class="display">Research-grade ML. Real software.</h1><p>A full catalog of work across applied AI, web products, graphics, databases, and systems.</p></header><section class="section"><div class="container"><div class="filters" aria-label="Filter projects">{['All','Research','Web App','Systems'].map((filter,i)=><button class:list={['filter',{active:i===0}]} data-filter={filter} aria-pressed={i===0}>{filter}</button>)}</div><div class="page-grid">{projects.map(project=><article class="card" data-project data-category={project.category}><div class="meta"><span class="eyebrow">{project.category}</span><span class="status">{project.status}</span></div><h2 class="display">{project.title}</h2><p class="muted">{project.description}</p><div class="tags">{project.tags.map((tag:string)=><span class="tag">{tag}</span>)}</div><div class="links">{project.liveUrl&&<a href={project.liveUrl} target="_blank" rel="noreferrer">Live ↗</a>}{project.githubUrl&&<a href={project.githubUrl} target="_blank" rel="noreferrer">GitHub ↗</a>}{project.sourceVisibility==='Private'&&<span>Private repository</span>}{project.sourceVisibility==='Unconfirmed'&&!project.liveUrl&&!project.githubUrl&&<span>Links to be confirmed</span>}</div></article>)}</div></div></section></main><SiteFooter /><script>const filters=[...document.querySelectorAll<HTMLButtonElement>('[data-filter]')];const cards=[...document.querySelectorAll<HTMLElement>('[data-project]')];filters.forEach(button=>button.addEventListener('click',()=>{const selected=button.dataset.filter;filters.forEach(item=>{const active=item===button;item.classList.toggle('active',active);item.setAttribute('aria-pressed',String(active))});cards.forEach(card=>card.hidden=selected!=='All'&&card.dataset.category!==selected)}));</script></BaseLayout>
<style>.filters{display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:1.5rem}.filter{min-height:44px;padding:.55rem .9rem;border:1px solid var(--border);border-radius:999px;background:transparent;color:var(--text-secondary);cursor:pointer}.filter:hover,.filter.active{border-color:var(--accent);background:var(--accent-soft);color:var(--text-primary)}[data-project][hidden]{display:none}.meta{display:flex;justify-content:space-between;gap:1rem}.status{font:.65rem "JetBrains Mono";color:var(--accent)}.card h2{font-size:clamp(1.5rem,3vw,2.2rem);margin:1.2rem 0 .5rem}.tags,.links{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:1.4rem}.links{min-height:44px;align-items:center;font:500 .7rem "JetBrains Mono";color:var(--text-tertiary)}.links a{color:var(--text-primary)}.links a:hover{color:var(--accent)}</style>

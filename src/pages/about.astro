---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SignalLine from '../components/SignalLine.astro';
import { Image } from 'astro:assets';
import portrait from '../assets/sabit-al-alfi-portrait-edited.png';
import { createCmsClient } from '../lib/cms/supabase';
import SectionManager from '../components/SectionManager.astro';

let skills = [
  ['Programming & data', 'Python, C, C++, SQL, HTML, Pandas, NumPy'],
  ['ML & deep learning', 'TensorFlow, PyTorch, CNNs, classification algorithms'],
  ['Explainable AI', 'Grad-CAM, interpretable computer vision, image processing'],
  ['Analysis & tools', 'Data cleaning, EDA, Matplotlib, Seaborn, LaTeX, Excel'],
];

let education = [
  { level: '03', period: 'JUN 2021 — DEC 2025', title: 'BSc in Computer Science & Engineering', institution: 'East West University, Dhaka', detail: 'Major in Data Science', result: 'CGPA 3.02 / 4.00' },
  { level: '02', period: '2019', title: 'Higher Secondary Certificate (HSC)', institution: 'Govt. Shah Sultan College, Bogra', detail: 'Science · Rajshahi Board', result: 'GPA 4.25 / 5.00' },
  { level: '01', period: '2017', title: 'Secondary School Certificate (SSC)', institution: 'APBn Public School and College, Bogra', detail: 'Science · Rajshahi Board', result: 'GPA 5.00 / 5.00' },
];

let coursework = [
  'Data Structures & Algorithms', 'Artificial Intelligence', 'Machine Learning',
  'Database Systems', 'Computer Graphics', 'Operating Systems',
  'Computer Networks', 'Statistics & Probability', 'Linear Algebra',
];

const fallbackCertifications = [
  { code: 'CRT / 01', title: 'Introduction to Python', provider: 'DataCamp', status: 'Completed', detail: 'Completed foundational training in Python syntax, data types, control flow, and practical programming.', complete: true },
  { code: 'CRT / 02', title: 'Associate Data Scientist in Python', provider: 'DataCamp', status: 'In progress', detail: 'An active learning track covering data manipulation, analysis, statistics, and machine-learning foundations.', complete: false },
];
let certifications = fallbackCertifications;
let thesis = { section_headline:'Research built to be understood.', title:'FetalCareXAI', subtitle:'A robust machine-learning framework for fetal health monitoring with explainable AI.', status:'Completed', institution:'East West University', discipline:'Computer Science & Engineering', supervisor:'Dr. Md. Atiqur Rahman', year:2025, related_url:'/projects', visible:true };
let community = [
  { organization:'Bangladesh Physics Olympiad', role_period:'BOGRA REGION · 2024–2025', description:'Supported regional learning and science-focused community activities.', url:null },
  { organization:'Volunteer for Bangladesh', role_period:'VOLUNTEER', description:'Contributed to collaborative community initiatives beyond software.', url:null },
];
let experiences:any[]=[];let achievements:any[]=[];
let profile:any={display_name:'Sabit Al Alfi',location:'Dhaka, Bangladesh',about_headline:'Curiosity across the stack.',about_intro:'I’m a Computer Science & Engineering graduate from East West University, specializing in Data Science and explainable AI.',about_principles_headline:'I like understanding systems from first principles.',about_focus:'My focus is building models that are not just accurate, but interpretable—alongside full-stack and systems-level engineering.',about_detail:'I care about how things actually work, whether that is a CNN’s attention map, a database schema, or a Linux boot process. I’m currently looking for Data Science, ML, and AI Engineer roles, with a longer-term goal of graduate research abroad.',portrait_url:null,portrait_alt:'Graduation portrait of Sabit Al Alfi',cv_url:'/Sabit-Al-Alfi-CV.pdf'};
if (Astro.locals.cmsConfigured) {
  const cms = createCmsClient(Astro.request, Astro.cookies)!;
  const [profileResult, certificationResult, educationResult, skillResult, courseworkResult, thesisResult, communityResult,experienceResult,achievementResult] = await Promise.all([
    cms.from('profile_content').select('*').eq('id','primary').maybeSingle(),
    cms.from('certifications').select('title,provider,status,description,sort_order').eq('visible',true).order('sort_order'),
    cms.from('education_records').select('period,title,institution,detail,result,sort_order').eq('visible',true).order('sort_order'),
    cms.from('skill_groups').select('title,skills,sort_order').eq('visible',true).order('sort_order'),
    cms.from('coursework').select('title,sort_order').eq('visible',true).order('sort_order'),
    cms.from('thesis_content').select('*').eq('id','primary').eq('visible',true).maybeSingle(),
    cms.from('community_entries').select('organization,role_period,description,url,sort_order').eq('visible',true).order('sort_order'),
    cms.from('experience_entries').select('*').eq('visible',true).order('sort_order'),
    cms.from('achievements').select('*').eq('visible',true).order('sort_order'),
  ]);
  if (profileResult.data) profile = { ...profile, ...profileResult.data };
  if (certificationResult.data?.length) certifications = certificationResult.data.map((item, index) => ({ code: `CRT / ${String(index + 1).padStart(2, '0')}`, title: item.title, provider: item.provider, status: item.status === 'completed' ? 'Completed' : 'In progress', detail: item.description, complete: item.status === 'completed' }));
  if (educationResult.data?.length) education = educationResult.data.map((item, index, records) => ({ ...item, level: String(records.length - index).padStart(2,'0') }));
  if (skillResult.data?.length) skills = skillResult.data.map(item => [item.title, item.skills.join(', ')]);
  if (courseworkResult.data?.length) coursework = courseworkResult.data.map(item => item.title);
  if (thesisResult.data) thesis = thesisResult.data;
  if (communityResult.data?.length) community = communityResult.data;
  experiences=experienceResult.data??[];achievements=achievementResult.data??[];
}
---
<BaseLayout title="About — Sabit Al Alfi" description="About Sabit Al Alfi: CSE graduate, Data Science major, explainable AI researcher, and software engineer.">
  <SiteNav />
  <main id="main-content">
    <header class="page-hero container about-hero">
      <div class="about-hero-copy"><p class="eyebrow">ABOUT / PROFILE</p><SignalLine />
        <h1 class="display">{profile.about_headline}</h1>
        <p>{profile.about_intro}</p>
        <div class="hero-actions"><a class="button primary" href={profile.cv_url} target="_blank">View résumé ↗</a><a class="text-link" href="/contact">Start a conversation →</a></div>
      </div>
      <figure class="portrait">{profile.portrait_url?<img src={profile.portrait_url} alt={profile.portrait_alt}/>:<Image src={portrait} alt={profile.portrait_alt} width={520} height={680} widths={[360,520,720]} sizes="(max-width: 760px) 100vw, 38vw" loading="eager" />}<figcaption><span>PROFILE / 01</span><strong>{profile.display_name}</strong><span>{profile.location}</span></figcaption></figure>
    </header>

    <section class="section">
      <div class="container about-grid">
        <div><p class="eyebrow">FIELD NOTE / 01</p><h2 class="display">{profile.about_principles_headline}</h2></div>
        <div><p class="lead">{profile.about_focus}</p><p class="muted">{profile.about_detail}</p></div>
      </div>
    </section>

    <section class="section">
      <div class="container"><header class="section-head"><p class="eyebrow">CAPABILITIES</p><SignalLine /><h2 class="display">A practical research toolkit.</h2></header>
        <div class="page-grid">{skills.map(([title,list], index) => <article class="card"><span class="record">SKL / 0{index + 1}</span><h3 class="display">{title}</h3><p class="muted">{list}</p></article>)}</div>
      </div>
    </section>

    {thesis.visible && <section class="section thesis-section">
      <div class="container thesis-grid">
        <header><p class="eyebrow">UNDERGRADUATE THESIS</p><SignalLine /><h2 class="display">{thesis.section_headline}</h2></header>
        <article class="thesis-record">
          <div class="record-line"><span>THS / 01</span><span>{thesis.status}</span></div>
          <h3 class="display">{thesis.title}</h3>
          <p class="thesis-subtitle">{thesis.subtitle}</p>
          <dl><div><dt>Institution</dt><dd>{thesis.institution}</dd></div><div><dt>Discipline</dt><dd>{thesis.discipline}</dd></div><div><dt>Supervisor</dt><dd>{thesis.supervisor}</dd></div><div><dt>Year</dt><dd>{thesis.year}</dd></div></dl>
          {thesis.related_url && <a class="text-link" href={thesis.related_url}>View related work →</a>}
        </article>
      </div>
    </section>}

    <section class="section">
      <div class="container"><header class="section-head"><p class="eyebrow">EDUCATION / BANGLADESH</p><SignalLine /><h2 class="display">Academic timeline.</h2><p class="muted">SSC → HSC → BSc in Computer Science & Engineering.</p></header>
        <div class="education-list">{education.map(item => <article><span class="level">{item.level}</span><div class="edu-main"><p class="eyebrow">{item.period}</p><h3 class="display">{item.title}</h3><p>{item.institution}</p><span class="muted">{item.detail}</span></div><span class="result">{item.result}</span></article>)}</div>
      </div>
    </section>

    <section class="section coursework-section">
      <div class="container coursework-grid"><header><p class="eyebrow">SELECTED COURSEWORK</p><SignalLine /><h2 class="display">Foundations behind the work.</h2><p class="muted">Core areas that support my work across data, machine learning, and software systems.</p></header><ol>{coursework.map((course, index) => <li><span>{String(index + 1).padStart(2, '0')}</span>{course}</li>)}</ol></div>
    </section>

    <section class="section credentials-section">
      <div class="container credentials-grid"><header><p class="eyebrow">CERTIFICATIONS / CONTINUOUS LEARNING</p><SignalLine /><h2 class="display">Learning stays active.</h2><p class="muted">Completed credentials and current structured learning, shown without invented percentage estimates.</p></header><div class="credential-list">{certifications.map(item => <article><div class="credential-top"><span>{item.code}</span><span class:list={['credential-status',{complete:item.complete}]}>{item.status}</span></div><h3 class="display">{item.title}</h3><p class="provider">{item.provider}</p><p class="muted">{item.detail}</p><div class:list={['progress-track',{active:!item.complete}]} role="progressbar" aria-label={`${item.title}: ${item.status}`} aria-valuemin="0" aria-valuemax="100" aria-valuenow={item.complete ? 100 : undefined} aria-valuetext={item.status}><span></span></div></article>)}</div></div>
    </section>

    <section class="section compact">
      {experiences.length>0&&<div class="container"><header class="section-head"><p class="eyebrow">EXPERIENCE</p><SignalLine /><h2 class="display small-heading">Work in practice.</h2></header><div class="education-list">{experiences.map((item,index)=><article><span class="level">{String(index+1).padStart(2,'0')}</span><div class="edu-main"><p class="eyebrow">{item.period}</p><h3 class="display">{item.title}</h3><p>{item.organization}{item.location?` · ${item.location}`:''}</p><span class="muted">{item.description}</span></div>{item.url&&<a class="result" href={item.url} target="_blank" rel="noreferrer">VIEW ↗</a>}</article>)}</div></div>}
      {achievements.length>0&&<div class="container achievement-block"><header class="section-head"><p class="eyebrow">AWARDS / HACKATHONS / PRESENTATIONS</p><SignalLine /><h2 class="display small-heading">Milestones and participation.</h2></header><div class="page-grid">{achievements.map(item=><article class="card"><span class="record">{item.kind}</span><h3 class="display">{item.title}</h3><p>{item.organization}</p><p class="muted">{item.description}</p>{item.url&&<a class="text-link" href={item.url} target="_blank" rel="noreferrer">View record ↗</a>}</article>)}</div></div>}
    </section>

    <section class="section compact">
      <div class="container about-grid"><div><p class="eyebrow">BEYOND THE CODE</p><h2 class="display small-heading">Community matters, too.</h2></div><ul class="community-list">{community.map(item => <li><span class="community-point" aria-hidden="true"></span><div><div class="community-meta">{item.url ? <a href={item.url} target="_blank" rel="noreferrer"><strong>{item.organization}</strong></a> : <strong>{item.organization}</strong>}<span>{item.role_period}</span></div><p>{item.description}</p></div></li>)}</ul></div>
    </section>
  </main>
  <SectionManager page="about" />
  <SiteFooter />
</BaseLayout>

<style>
  .about-hero{display:grid;grid-template-columns:minmax(0,1.15fr) minmax(280px,.72fr);gap:clamp(2rem,7vw,6rem);align-items:end}.about-hero-copy{padding-bottom:clamp(1rem,4vw,3rem)}.about-hero-copy>p:last-of-type{max-width:620px}.hero-actions{display:flex;align-items:center;flex-wrap:wrap;gap:1rem;margin-top:1.7rem}.portrait{position:relative;margin:0;border:1px solid var(--border);background:var(--surface);overflow:hidden}.portrait:before{content:"";position:absolute;inset:0;z-index:1;box-shadow:inset 0 0 0 8px var(--bg);pointer-events:none}.portrait :global(img){display:block;width:100%;height:clamp(400px,54vw,620px);object-fit:cover;object-position:center 36%;filter:saturate(.82) contrast(1.03)}.portrait figcaption{position:absolute;z-index:2;inset:auto 9px 9px 9px;display:grid;grid-template-columns:auto 1fr auto;gap:.8rem;padding:.8rem 1rem;border:1px solid var(--border);background:color-mix(in srgb,var(--bg),transparent 10%);backdrop-filter:blur(10px);font:.56rem "JetBrains Mono";letter-spacing:.06em;text-transform:uppercase}.portrait figcaption strong{text-align:center;color:var(--text-primary)}.portrait figcaption span{color:var(--text-tertiary)}
  .about-grid{display:grid;grid-template-columns:1fr 1.4fr;gap:clamp(2rem,7vw,7rem)}.about-grid h2{margin:1rem 0 0;font-size:clamp(2.1rem,4.2vw,3.75rem);line-height:1.03}.lead{font-size:1.15rem;margin-top:0}.card h3{margin:0 0 .8rem;font-size:1.4rem;text-transform:capitalize}.record{display:block;margin-bottom:1.5rem;font:500 .58rem "JetBrains Mono";letter-spacing:.1em;color:var(--text-tertiary)}
  .thesis-section{background:color-mix(in srgb,var(--surface),transparent 35%)}.thesis-grid{display:grid;grid-template-columns:.8fr 1.5fr;gap:clamp(2rem,7vw,7rem)}.thesis-grid header h2{font-size:clamp(1.9rem,3.4vw,3rem);line-height:1.06}.thesis-record{border-block:1px solid var(--border);padding:1.5rem 0}.record-line{display:flex;justify-content:space-between;font:500 .62rem "JetBrains Mono";letter-spacing:.1em;color:var(--accent)}.thesis-record h3{font-size:clamp(2.35rem,4.8vw,4.1rem);margin:1.5rem 0 .2rem}.thesis-subtitle{max-width:600px;color:var(--text-secondary)}dl{display:grid;grid-template-columns:1fr 1fr;margin:2rem 0;border-top:1px solid var(--border)}dl div{padding:1rem 0;border-bottom:1px solid var(--border)}dt{font:.6rem "JetBrains Mono";text-transform:uppercase;color:var(--text-tertiary)}dd{margin:.25rem 0 0}.text-link{display:inline-flex;min-height:44px;align-items:center;font-weight:500}.text-link:hover{color:var(--accent)}
  .education-list{border-top:1px solid var(--border)}.education-list article{display:grid;grid-template-columns:70px 1fr auto;gap:1.5rem;padding:2rem 0;border-bottom:1px solid var(--border);align-items:start}.level{font:500 .75rem "JetBrains Mono";color:var(--accent)}.edu-main h3{font-size:clamp(1.5rem,3vw,2.4rem);margin:.7rem 0 .2rem}.edu-main p{margin:.2rem 0}.result{padding:.35rem .6rem;border:1px solid var(--border);font:.62rem "JetBrains Mono";color:var(--text-tertiary)}
  .coursework-grid{display:grid;grid-template-columns:.8fr 1.4fr;gap:clamp(2rem,7vw,7rem)}.coursework-grid h2{font-size:clamp(2rem,4vw,3.5rem);line-height:1.05}.coursework-grid ol{margin:0;padding:0;list-style:none;border-top:1px solid var(--border)}.coursework-grid li{display:grid;grid-template-columns:45px 1fr;padding:.8rem 0;border-bottom:1px solid var(--border)}.coursework-grid li span{font:.65rem "JetBrains Mono";color:var(--accent)}.compact{padding-block:3rem}.small-heading{font-size:clamp(1.8rem,3vw,2.7rem)!important}.community-list{margin:0;padding:0;list-style:none;border-top:1px solid var(--border)}.community-list li{display:grid;grid-template-columns:12px 1fr;gap:.9rem;padding:1rem 0;border-bottom:1px solid var(--border)}.community-point{width:7px;height:7px;margin-top:.5rem;border:2px solid var(--bg);border-radius:50%;background:var(--accent);box-shadow:0 0 0 1px var(--accent)}.community-meta{display:flex;justify-content:space-between;gap:1rem;align-items:baseline}.community-meta strong{font:500 1rem "Space Grotesk"}.community-meta span{font:.58rem "JetBrains Mono";letter-spacing:.08em;color:var(--text-tertiary)}.community-list p{margin:.3rem 0 0;color:var(--text-secondary);font-size:.9rem}
  .credentials-section{background:color-mix(in srgb,var(--surface),transparent 45%)}.credentials-grid{display:grid;grid-template-columns:.8fr 1.4fr;gap:clamp(2rem,7vw,7rem)}.credentials-grid header h2{font-size:clamp(2rem,4vw,3.5rem);line-height:1.05}.credential-list{border-top:1px solid var(--border)}.credential-list article{padding:1.6rem 0;border-bottom:1px solid var(--border)}.credential-top{display:flex;justify-content:space-between;gap:1rem;font:.6rem "JetBrains Mono";letter-spacing:.08em;color:var(--text-tertiary);text-transform:uppercase}.credential-status{padding:.25rem .5rem;border:1px solid var(--border)}.credential-status.complete{border-color:var(--accent);color:var(--accent)}.credential-list h3{margin:1rem 0 .2rem;font-size:clamp(1.45rem,2.6vw,2.1rem)}.provider{margin:.2rem 0;font:.68rem "JetBrains Mono";color:var(--accent);text-transform:uppercase}.credential-list .muted{max-width:650px;font-size:.9rem}.progress-track{height:4px;margin-top:1.2rem;overflow:hidden;background:var(--border)}.progress-track span{display:block;width:100%;height:100%;background:var(--accent)}.progress-track.active span{background:repeating-linear-gradient(90deg,var(--accent) 0 12px,transparent 12px 18px)}
  @media(max-width:760px){.about-hero,.about-grid,.thesis-grid,.coursework-grid,.credentials-grid{grid-template-columns:1fr;gap:2rem}.about-hero{padding-top:3rem}.about-hero-copy{padding-bottom:0}.portrait{max-width:520px}.portrait :global(img){height:min(125vw,600px)}.portrait figcaption{grid-template-columns:1fr}.portrait figcaption strong{text-align:left}.education-list article{grid-template-columns:38px 1fr}.result{grid-column:2;width:max-content}dl{grid-template-columns:1fr}.community-meta{display:grid;gap:.2rem}}
</style>

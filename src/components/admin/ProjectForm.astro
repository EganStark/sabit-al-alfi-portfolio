---
const { project = {}, mode } = Astro.props; const action=mode==='create'?'/api/admin/projects/new':`/api/admin/projects/${project.id}`;
---
<form class="panel form-grid" method="post" action={action}>
 <div class="field"><label for="title">TITLE</label><input id="title" name="title" value={project.title??''} required /></div><div class="field"><label for="category">CATEGORY</label><select id="category" name="category">{['Research','Web App','Systems'].map(x=><option selected={project.category===x}>{x}</option>)}</select></div>
 <div class="field"><label for="status">STATUS</label><select id="status" name="status">{['Complete','In Progress'].map(x=><option selected={project.status===x}>{x}</option>)}</select></div><div class="field"><label for="sort_order">ORDER</label><input id="sort_order" name="sort_order" type="number" min="0" value={project.sort_order??0} /></div>
 <div class="field full"><label for="description">DESCRIPTION</label><textarea id="description" name="description" maxlength="1000" required>{project.description??''}</textarea></div><div class="field full"><label for="tags">TECHNOLOGIES / TAGS</label><input id="tags" name="tags" value={project.tags?.join(', ')??''} /></div>
 <div class="field"><label for="github_url">GITHUB URL</label><input id="github_url" name="github_url" type="url" value={project.github_url??''} /></div><div class="field"><label for="live_url">LIVE URL</label><input id="live_url" name="live_url" type="url" value={project.live_url??''} /></div>
 <div class="field"><label for="source_visibility">SOURCE</label><select id="source_visibility" name="source_visibility">{['Public','Private','Unconfirmed'].map(x=><option selected={project.source_visibility===x}>{x}</option>)}</select></div><label class="check"><input type="checkbox" name="featured" value="true" checked={project.featured}/> Featured project</label><label class="check"><input type="checkbox" name="visible" value="true" checked={project.visible??true}/> Show publicly</label>
 <div class="field full admin-actions"><button class="admin-button primary">Save project</button><a class="admin-button" href="/admin/projects">Cancel</a></div>
</form>

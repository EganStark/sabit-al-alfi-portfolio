---
const{paper={},mode}=Astro.props;const action=mode==='create'?'/api/admin/research/new':`/api/admin/research/${paper.id}`;
---
<form class="panel form-grid" method="post" action={action}><div class="field full"><label>TITLE</label><input name="title" value={paper.title??''} required/></div><div class="field"><label>STATUS</label><select name="status">{['Published','Accepted'].map(x=><option selected={paper.status===x}>{x}</option>)}</select></div><div class="field"><label>PUBLISHER</label><select name="publisher">{['IEEE','Springer'].map(x=><option selected={paper.publisher===x}>{x}</option>)}</select></div><div class="field full"><label>ABSTRACT / SUMMARY</label><textarea name="abstract" required>{paper.abstract??''}</textarea></div><div class="field full"><label>VENUE</label><input name="venue" value={paper.venue??''} required/></div><div class="field"><label>YEAR</label><input name="publication_year" type="number" min="1900" max="2200" value={paper.publication_year??new Date().getFullYear()} required/></div><div class="field"><label>DOI</label><input name="doi" value={paper.doi??''} required/></div><div class="field full"><label>PUBLICATION URL</label><input name="publication_url" type="url" value={paper.publication_url??''}/></div><div class="field"><label>AUTHORSHIP</label><select name="authorship_label">{['First author','Second author','Co-author'].map(x=><option selected={paper.authorship_label===x}>{x}</option>)}</select></div><div class="field"><label>YOUR POSITION</label><input name="author_position" type="number" min="1" value={paper.author_position??1}/></div><div class="field"><label>TOTAL AUTHORS</label><input name="author_count" type="number" min="1" value={paper.author_count??1}/></div><div class="field"><label>DISPLAY ORDER</label><input name="sort_order" type="number" min="0" value={paper.sort_order??0}/></div><label class="check"><input name="visible" type="checkbox" value="true" checked={paper.visible??true}/> Show publicly</label><div class="field full admin-actions"><button class="admin-button primary">Save paper</button><a class="admin-button" href="/admin/research">Cancel</a></div></form>
